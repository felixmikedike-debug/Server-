<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title><%= title %></title>
  <style>
    :root {
      --primary: #1564C0;
      --primary-light: #3485e5;
    }
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
    }
    body {
      font-family: 'Segoe UI', system-ui, Arial, sans-serif;
      background: #FFFFFF;
      color: #343a40;
      line-height: 1.7;
      min-height: 100vh;
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 20px;
    }
    .form-container {
      max-width: 500px;
      width: 100%;
      background: #FFFFFF;
      border-radius: 24px;
      overflow: hidden;
      box-shadow: 0 20px 60px rgba(0,0,0,0.08);
      padding: 50px 40px 60px;
      display: flex;
      flex-direction: column;
    }
    button {
      width: 100%;
      padding: 18px;
      background: var(--primary);
      color: white;
      border: none;
      font-weight: 600;
      cursor: pointer;
      border-radius: 12px;
      font-size: 18px;
    }
    button:hover {
      background: var(--primary-light);
    }
    button:disabled {
      opacity: 0.6;
      cursor: default;
    }

    /* Simple underlined footer link */
    .footer {
      margin-top: auto;
      padding-top: 40px;
      text-align: center;
    }
    .footer-link {
      color: #666;
      text-decoration: underline;
      font-size: 14px;
      transition: color 0.2s ease;
    }
    .footer-link:hover {
      color: var(--primary);
    }
  </style>
</head>
<body>
  <div class="form-container">
    <div id="form-content"></div>

    <!-- Simple underlined footer link -->
    <div class="footer">
      <a href="https://sendi.onrender.com" class="footer-link" target="_blank" rel="noopener">
        Join Sendi
      </a>
    </div>
  </div>

  <script>
    const state = JSON.parse('<%- JSON.stringify(state || {}) %>');
    const subscribeLink = <%- JSON.stringify(subscribeLink || null) %>;

    const container = document.getElementById('form-content');

    const button = document.createElement('button');
    button.textContent = (state && state.buttonText) || 'Subscribe';
    button.style.background = (state && state.buttonColor) || 'var(--primary)';
    button.style.color = (state && state.buttonTextColor) || '#ffffff';
    container.appendChild(button);

    if (!subscribeLink) {
      button.disabled = true;
      button.textContent = 'Subscription unavailable';
    }

    button.addEventListener('click', (e) => {
      e.preventDefault();
      if (!subscribeLink) return;
      window.location.href = subscribeLink;
    });
  </script>
</body>
</html>
